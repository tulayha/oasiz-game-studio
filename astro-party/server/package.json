{
  "name": "astro-party-colyseus-server",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env dist/server/src/index.js",
    "loadtest": "npm run loadtest:roomcode --",
    "loadtest:roomcode": "tsx --env-file-if-exists=../.env --env-file-if-exists=.env loadtest/run-roomcode-loadtest.ts",
    "loadtest:lobbyfill": "tsx --env-file-if-exists=../.env --env-file-if-exists=.env loadtest/run-lobbyfill-loadtest.ts",
    "loadtest:capacity": "tsx --env-file-if-exists=../.env --env-file-if-exists=.env loadtest/run-capacity-sweep.ts"
  },
  "dependencies": {
    "@colyseus/monitor": "^0.16.7",
    "@colyseus/schema": "^3.0.69",
    "@colyseus/ws-transport": "^0.16.5",
    "colyseus": "^0.16.5",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "matter-js": "^0.20.0",
    "poly-decomp": "^0.3.0"
  },
  "devDependencies": {
    "@colyseus/loadtest": "^0.16.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/matter-js": "^0.19.8",
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
