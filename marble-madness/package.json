{
  "name": "marble-madness",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:restart": "bash scripts/restart-dev.sh",
    "dev:restart:bg": "bash scripts/restart-dev-background.sh",
    "build": "vite build",
    "build:versioned": "node scripts/bump-build-version.mjs && vite build",
    "build:versioned:serve": "npm run build:versioned && npm run dev:restart",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.{ts,tsx,css,html}'"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "three": "^0.181.1"
  },
  "devDependencies": {
    "@types/three": "^0.181.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vite-plugin-singlefile": "^2.0.3"
  }
}
